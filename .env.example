# ============================================================================
# TouchBaseAI — deployment environment. Copy to `.env` and fill in real values.
#   cp .env.example .env
# This file is read by docker-compose (backend env_file + Caddy DOMAIN).
# ============================================================================

# ---- Database: Supabase pooled connections ----
# Transaction pooler (app runtime, port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (used only for `prisma migrate deploy`, port 5432)
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres"

# ---- Auth / encryption ----
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=<long-random-string>
JWT_EXPIRES_IN=7d
# 32-byte hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: changing this later makes existing encrypted Settings unreadable.
ENCRYPTION_KEY=<32-byte-hex>

# ---- App ----
NODE_ENV=production
PORT=5000
# Public HTTPS URL of THIS deployment — required for Twilio/Retell webhooks.
PUBLIC_BASE_URL=https://your-domain.com
# Allowed browser origins. Same-origin via Caddy, so this is mainly a safety net.
CORS_ORIGINS=https://your-domain.com

# ---- Reverse proxy (Caddy) ----
# Domain with a DNS A record pointing to the server IP. Caddy auto-provisions
# HTTPS. For IP-only testing without a domain, set DOMAIN=:80
DOMAIN=your-domain.com
