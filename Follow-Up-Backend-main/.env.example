PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=generate-with-node-e-require-crypto-randomBytes-32-toString-hex

# Comma-separated list of allowed frontend origins for CORS.
# Add your deployed frontend URL here in production (no trailing slash).
# Example: CORS_ORIGINS=http://localhost:8080,https://app.yourdomain.com
CORS_ORIGINS=

# Public HTTPS URL for Twilio WhatsApp StatusCallback (required for delivery status).
# Local dev: run `ngrok http 5000` and paste the https URL (no trailing slash).
# Example: PUBLIC_BASE_URL=https://abc123.ngrok-free.app
PUBLIC_BASE_URL=
